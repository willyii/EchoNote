{
  "manifest_version": 3,
  "name": "EchoNote",
  "version": "1.0",
  "description": "Voice-to-text dictation that sends spoken notes directly to AI models like Gemini.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open EchoNote"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
